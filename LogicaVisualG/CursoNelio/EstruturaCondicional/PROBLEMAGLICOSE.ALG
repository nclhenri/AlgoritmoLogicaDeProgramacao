Algoritmo "problema_glicose"

Var

   glicose : inteiro

Inicio

      escreva("Digite a medida da glicose: ")
      leia(glicose)

      se glicose <= 100 entao
      escreval("Classificaçăo: Normal")
      senao
           se (glicose > 100) e (glicose <= 140) entao
           escreval("Classificaçăo: Elevada")
           senao
                escreval("Classificaçăo: Diabetes")
           fimse
      fimse

Fimalgoritmo